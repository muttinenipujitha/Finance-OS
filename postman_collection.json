{
  "info": {
    "name": "Finance API – Test Suite",
    "description": "Covers authentication, transactions, dashboard, users, and security scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "txId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Admin\",\"email\":\"admin@test.com\",\"password\":\"Admin123\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const d = pm.response.json().data;",
                "pm.collectionVariables.set('adminToken', d.accessToken);",
                "pm.collectionVariables.set('refreshToken', d.refreshToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@test.com\",\"password\":\"Admin123\"}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          }
        }
      ]
    },

    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const d = pm.response.json().data;",
                "pm.collectionVariables.set('txId', d.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\":5000,\"type\":\"INCOME\",\"category\":\"Salary\",\"date\":\"2024-06-01\"}"
            }
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions/{{txId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/transactions/{{txId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"notes\":\"Updated\"}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/transactions/{{txId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },

    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Trends",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/trends?period=monthly&months=12",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },

    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/role",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"role\":\"ANALYST\"}"
            }
          }
        }
      ]
    },

    {
      "name": "Security",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/health"
          }
        },
        {
          "name": "Invalid Route",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/invalid"
          }
        }
      ]
    }

  ]
}